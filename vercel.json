{
	"version": 2,
	"builds": [
		{
			"src": "api/index.js",
			"use": "@vercel/node",
			"config": {
				"includeFiles": [
					"views/**",
					"models/**"
				]
			}
		}
	],
	"routes": [
		{
			"src": "/health",
			"dest": "/api/index.js"
		},
		{
			"src": "/(.*)",
			"dest": "/api/index.js"
		}
	]
}