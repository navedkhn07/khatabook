<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script>
      tailwind = window.tailwind || {};
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['Poppins', 'sans-serif']
            },
            boxShadow: {
              soft: '0 18px 45px -25px rgba(34, 197, 94, 0.35)'
            }
          }
        }
      };
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <% const displayTitle = (title || '').replace(/\.txt$/i, ''); %>
    <title>Khatabook | Edit Hisaab</title>
    <link
    href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css"
    rel="stylesheet"
  />
</head>
<body class="font-sans min-h-screen text-slate-800 bg-[radial-gradient(circle_at_top,_rgba(220,252,231,0.95),_transparent_34%),linear-gradient(180deg,_#f6fbf4_0%,_#eef8ec_100%)]">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div class="absolute -top-20 -left-16 h-72 w-72 rounded-full bg-emerald-200/35 blur-3xl"></div>
      <div class="absolute top-28 right-0 h-80 w-80 rounded-full bg-lime-200/35 blur-3xl"></div>
    </div>
    <div id="main" class="mx-auto max-w-5xl px-4 py-4 sm:px-6 sm:py-6 lg:px-8">
        <nav class="rounded-[28px] border border-white/70 bg-white/85 px-5 py-4 shadow-soft backdrop-blur-xl">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div class="flex items-center gap-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-500 to-lime-500 text-white shadow-lg shadow-emerald-500/25">
                <i class="ri-wallet-3-fill text-xl"></i>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700/70">Khatabook</p>
                <h2 class="text-xl font-bold text-slate-900">Hisab-Kitab</h2>
              </div>
            </div>
            <div class="flex flex-wrap items-center gap-2 sm:gap-3">
              <a href="/" class="rounded-full border border-emerald-100 bg-white px-4 py-2 text-sm font-semibold text-emerald-800 transition hover:border-emerald-200 hover:bg-emerald-50">Home</a>
              <a href="/create" class="rounded-full border border-emerald-100 bg-emerald-50 px-4 py-2 text-sm font-semibold text-emerald-800 transition hover:border-emerald-200 hover:bg-emerald-100">New Hisaab</a>
              <a href="/createByTime" class="rounded-full border border-emerald-100 bg-white px-4 py-2 text-sm font-semibold text-emerald-800 transition hover:border-emerald-200 hover:bg-emerald-50">Save With Date</a>
              <% if (currentUser) { %>
                <form action="/logout" method="post"><button class="rounded-full border border-rose-100 bg-rose-50 px-4 py-2 text-sm font-semibold text-rose-700 transition hover:bg-rose-100">Logout (<%= currentUser.name %>)</button></form>
              <% } else { %>
                <a href="/login" class="rounded-full border border-emerald-100 bg-white px-4 py-2 text-sm font-semibold text-emerald-800 transition hover:border-emerald-200 hover:bg-emerald-50">Login</a>
              <% } %>
            </div>
          </div>
        </nav>

        <section class="mt-6 grid gap-6 lg:grid-cols-[1fr_0.9fr] lg:items-center">
          <div class="rounded-[32px] border border-white/70 bg-white/80 p-6 shadow-soft backdrop-blur-xl sm:p-8">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-emerald-700/70">Editing mode</p>
            <h1 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">Edit <span class="text-emerald-700"><%= displayTitle %></span></h1>
            <p class="mt-4 max-w-2xl text-sm leading-6 text-slate-600 sm:text-base">Refine the title or update the note content while keeping the same simple flow.</p>
          </div>
          <div class="rounded-[32px] border border-emerald-100 bg-gradient-to-br from-emerald-600 to-lime-500 p-6 text-white shadow-soft sm:p-8">
            <div class="flex items-center justify-between">
              <p class="text-sm font-medium text-white/85">Safe updates</p>
              <i class="ri-edit-2-line text-2xl text-white/90"></i>
            </div>
            <p class="mt-5 text-sm leading-6 text-white/85">The same note, now with a softer and more polished writing space.</p>
          </div>
        </section>

        <div id="center" class="mt-8 sm:mt-10">
          <div class="rounded-[32px] border border-white/70 bg-white/90 p-5 shadow-soft sm:p-8">
            <form action="/update/<%= id %>" method="post" class="flex w-full max-w-3xl flex-col gap-4">
              <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700">Title</label>
                <input type="text" value="<%= displayTitle %>" placeholder="Shopping ka hisaab, ghar ka hisaab..." name="title" class="w-full rounded-2xl border border-emerald-100 bg-[#fbfffb] p-4 text-slate-800 placeholder:text-slate-400 shadow-inner shadow-emerald-50 focus:border-emerald-400 focus:outline-none focus:ring-4 focus:ring-emerald-100">
              </div>
              <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700">Notes</label>
                <textarea class="min-h-[22rem] w-full resize-none rounded-2xl border border-emerald-100 bg-[#fbfffb] p-4 text-slate-800 placeholder:text-slate-400 shadow-inner shadow-emerald-50 focus:border-emerald-400 focus:outline-none focus:ring-4 focus:ring-emerald-100 sm:min-h-[28rem]" name="filedata" placeholder="aata daal cheeni..."><%= data %></textarea>
              </div>
              <div class="flex flex-wrap items-center gap-3">
                <input type="submit" class="inline-flex cursor-pointer items-center gap-2 rounded-full bg-emerald-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-500/25 transition hover:bg-emerald-700">
                <p class="text-sm text-slate-500">Your changes will update this hisaab only.</p>
              </div>
            </form>
          </div>
        </div>
      </div>
</body>
</html>